NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# Use either DATABASE_URL or the standard PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD variables.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lead_management

# Replace these with long random values before production.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7
BCRYPT_ROUNDS=12

# Required only for POST /api/auth/setup-admin.
SETUP_ADMIN_TOKEN=replace-with-one-time-admin-setup-token
